<?xml version="1.0" encoding="utf-8"?>
<!--
  Neon Nocturne — Launcher Foreground
  A stylized tavern beer stein with foam crown.
  Amber body, cream foam, subtle glow detail.
  Viewport 108dp for adaptive icon safe zone (inner 66dp).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group centered at 54,54 for adaptive icon safe zone -->
    <group
        android:translateX="21"
        android:translateY="21">

        <!-- Mug body — warm amber trapezoid -->
        <path
            android:fillColor="#D4A853"
            android:pathData="M22,28 L44,28 L42,56 L24,56 Z" />

        <!-- Mug body highlight — lighter amber stripe -->
        <path
            android:fillColor="#F0C969"
            android:fillAlpha="0.5"
            android:pathData="M26,30 L40,30 L39,54 L27,54 Z" />

        <!-- Mug handle — curved arc -->
        <path
            android:fillColor="@android:color/transparent"
            android:strokeColor="#D4A853"
            android:strokeWidth="4"
            android:pathData="M44,34 Q52,34 52,42 Q52,50 44,50" />

        <!-- Foam base — oval cap -->
        <path
            android:fillColor="#F5EDD6"
            android:pathData="M20,28 Q33,24 46,28 Q46,32 44,34 Q33,30 22,34 Q20,32 20,28 Z" />

        <!-- Foam bubble left -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.9"
            android:pathData="M22,22 m-4,0 a4,4 0 1,1 8,0 a4,4 0 1,1 -8,0" />

        <!-- Foam bubble center -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.85"
            android:pathData="M30,19 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0" />

        <!-- Foam bubble right -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.9"
            android:pathData="M40,22 m-4,0 a4,4 0 1,1 8,0 a4,4 0 1,1 -8,0" />

        <!-- Foam bubble top-left small -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.7"
            android:pathData="M26,17 m-2.5,0 a2.5,2.5 0 1,1 5,0 a2.5,2.5 0 1,1 -5,0" />

        <!-- Foam bubble top-right small -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.7"
            android:pathData="M36,16 m-3,0 a3,3 0 1,1 6,0 a3,3 0 1,1 -6,0" />

        <!-- Subtle inner glow — bottom of mug -->
        <path
            android:fillColor="#F0C969"
            android:fillAlpha="0.3"
            android:pathData="M26,50 Q33,48 40,50 Q33,55 26,50 Z" />

    </group>
</vector>
